{
  "name": "projector-app",
  "version": "1.4.5",
  "description": "A Markdown + Mermaid-gantt project planner with a minimalist frameless UI.",
  "main": "main.js",
  "homepage": "https://github.com/lhdharris/projector",
  "author": {
    "name": "Louis Harris",
    "email": "lhd.louis.harris@gmail.com"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux rpm",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis",
    "dist:deb": "electron-builder --linux deb",
    "dist:all-on-mac": "electron-builder --mac dmg --win nsis --linux deb"
  },
  "build": {
    "appId": "com.louisharris.projector",
    "productName": "Projector",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "share-server.js",
      "share/**/*",
      "renderer/**/*",
      "assets/**/*"
    ],
    "linux": {
      "target": [
        "rpm"
      ],
      "category": "Office",
      "icon": "build/icons",
      "maintainer": "Louis Harris <lhd.louis.harris@gmail.com>"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icons/1024x1024.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/256x256.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "mermaid": "^11.15.0"
  }
}
